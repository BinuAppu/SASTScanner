#!/usr/bin/env bash
# =============================================================================
#  sastscan installer – installs / updates all SAST tools & rule sets
#  Target directory : /opt/tools/SASTScanner
# =============================================================================

set -uo pipefail

VERSION="1.0.0"
TOOLS_DIR="/opt/tools/SASTScanner"
BIN_DIR="${TOOLS_DIR}/bin"
RULES_DIR="${TOOLS_DIR}/rules"
VENV_DIR="${TOOLS_DIR}/venv"
LIB_SRC="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'; DIM='\033[2m'

ts()        { date '+%H:%M:%S'; }
log_info()  { echo -e "${BLUE}[INFO]${NC}    $(ts) │ $*"; }
log_ok()    { echo -e "${GREEN}[OK]${NC}      $(ts) │ $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}    $(ts) │ $*"; }
log_error() { echo -e "${RED}[ERROR]${NC}   $(ts) │ $*" >&2; }
log_step()  { echo -e "\n${BOLD}${CYAN}── $* ${NC}"; }
log_skip()  { echo -e "${DIM}[SKIP]${NC}    $(ts) │ $*"; }

banner() {
    echo ""
    echo -e "${BOLD}${CYAN}╔═══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${CYAN}║        sastscan Installer  ─  Version ${VERSION}                   ║${NC}"
    echo -e "${BOLD}${CYAN}║        Installing tools to: ${TOOLS_DIR}     ║${NC}"
    echo -e "${BOLD}${CYAN}╚═══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

# ── Helpers ───────────────────────────────────────────────────────────────────

require_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "This installer must be run as root (use sudo)"
        exit 1
    fi
}

detect_os() {
    OS=""
    if   [[ -f /etc/debian_version ]]; then OS="debian"
    elif [[ -f /etc/redhat-release ]]; then OS="rhel"
    elif [[ -f /etc/arch-release    ]]; then OS="arch"
    else                                     OS="unknown"
    fi
    log_info "Detected OS family: ${OS}"
}

pkg_install() {
    case "${OS}" in
        debian) apt-get install -y -q "$@" ;;
        rhel)   yum install -y -q "$@" 2>/dev/null || dnf install -y -q "$@" ;;
        arch)   pacman -S --noconfirm --quiet "$@" ;;
        *)      log_warn "Unknown OS — skipping package: $*" ;;
    esac
}

get_latest_gh_release() {
    # $1 = owner/repo  → prints latest tag
    curl -fsSL "https://api.github.com/repos/$1/releases/latest" \
        2>/dev/null | grep '"tag_name"' | head -1 | sed 's/.*"tag_name":\s*"\([^"]*\)".*/\1/'
}

arch_name() {
    local a; a=$(uname -m)
    case "${a}" in
        x86_64|amd64) echo "amd64" ;;
        aarch64|arm64) echo "arm64" ;;
        *)             echo "${a}" ;;
    esac
}

# ── Directory setup ───────────────────────────────────────────────────────────

setup_dirs() {
    log_step "Creating directory structure"
    mkdir -p "${TOOLS_DIR}" "${BIN_DIR}" "${RULES_DIR}/semgrep" \
             "${RULES_DIR}/yara" "${TOOLS_DIR}/lib" "${VENV_DIR}"
    log_ok "Directory structure ready: ${TOOLS_DIR}"
}

# ── System packages ───────────────────────────────────────────────────────────

# Returns 0 if a Debian package is already installed, 1 otherwise
_deb_installed() { dpkg -l "$1" 2>/dev/null | grep -q "^ii"; }

install_system_deps() {
    log_step "Installing system dependencies"

    case "${OS}" in
        debian)
            # Force IPv4 — WSL resolves IPv6 apt mirrors very slowly
            local APT="apt-get -o Acquire::ForceIPv4=true"

            # Only refresh the package index if it is older than 1 hour
            local list_ts=0
            [[ -d /var/lib/apt/lists ]] && \
                list_ts=$(find /var/lib/apt/lists -maxdepth 1 -name "*.gz" \
                          -printf '%T@\n' 2>/dev/null | sort -n | tail -1 | cut -d. -f1)
            list_ts=${list_ts:-0}
            local now; now=$(date +%s)
            if (( now - list_ts > 3600 )); then
                log_info "Refreshing package index (forced IPv4)..."
                ${APT} update -qq
            else
                log_info "Package index is fresh (< 1 h old) — skipping apt-get update"
            fi

            # ── Group 1: essential tools (small, fast) ────────────────────────
            local essential=(curl wget unzip git jq python3 python3-pip python3-venv)
            local need=()
            for pkg in "${essential[@]}"; do
                _deb_installed "${pkg}" || need+=("${pkg}")
            done
            if [[ ${#need[@]} -gt 0 ]]; then
                log_info "Installing: ${need[*]}"
                ${APT} install -y -q "${need[@]}"
            else
                log_ok "Essential tools already present — skipped"
            fi

            # ── Group 2: Java — needed only for OWASP Dependency Check ────────
            if ! command -v java &>/dev/null; then
                log_info "Installing Java 17 (required for OWASP Dependency Check)..."
                ${APT} install -y -q openjdk-17-jre-headless
            else
                log_ok "Java already present: $(java -version 2>&1 | head -1)"
            fi

            # ── Group 3: YARA — prefer apt binary; build from source only if unavailable ──
            if command -v yara &>/dev/null; then
                log_ok "YARA already present: $(yara --version 2>/dev/null)"
            elif ${APT} install -y -q yara 2>/dev/null; then
                log_ok "YARA installed via apt: $(yara --version 2>/dev/null)"
            else
                # apt has no yara package on this distro — install build toolchain
                log_info "YARA not in apt — installing build tools for source compilation..."
                local build=(build-essential libssl-dev libffi-dev python3-dev \
                             cmake automake libtool pkg-config)
                local bneed=()
                for pkg in "${build[@]}"; do
                    _deb_installed "${pkg}" || bneed+=("${pkg}")
                done
                [[ ${#bneed[@]} -gt 0 ]] && ${APT} install -y -q "${bneed[@]}"
                log_ok "Build tools ready"
            fi
            ;;

        rhel)
            pkg_install curl wget unzip git jq python3 python3-pip \
                        java-17-openjdk gcc gcc-c++ make openssl-devel \
                        libffi-devel python3-devel cmake automake libtool
            ;;
        arch)
            pkg_install curl wget unzip git jq python python-pip \
                        jdk17-openjdk base-devel openssl libffi cmake automake libtool
            ;;
    esac
    log_ok "System dependencies ready"
}

# ── Python virtualenv ─────────────────────────────────────────────────────────

setup_venv() {
    log_step "Setting up Python virtual environment"
    if [[ ! -f "${VENV_DIR}/bin/activate" ]]; then
        python3 -m venv "${VENV_DIR}"
        log_ok "Virtualenv created: ${VENV_DIR}"
    else
        log_ok "Virtualenv already exists — updating"
    fi

    # shellcheck disable=SC1091
    source "${VENV_DIR}/bin/activate"
    pip install --quiet --upgrade pip wheel setuptools
    # checkov requires packaging>=23.0,<24.0 — force-reinstall exact version to avoid conflicts
    pip install --quiet --force-reinstall --no-deps "packaging==23.2"
}

# ── Python tools ──────────────────────────────────────────────────────────────

install_semgrep() {
    log_step "Installing Semgrep"
    source "${VENV_DIR}/bin/activate"
    pip install --quiet --upgrade semgrep
    ln -sf "${VENV_DIR}/bin/semgrep" "${BIN_DIR}/semgrep" 2>/dev/null || true
    local ver; ver=$("${VENV_DIR}/bin/semgrep" --version 2>/dev/null | head -1)
    log_ok "Semgrep installed: ${ver}"
}

install_bandit() {
    log_step "Installing Bandit"
    source "${VENV_DIR}/bin/activate"
    pip install --quiet --upgrade bandit
    ln -sf "${VENV_DIR}/bin/bandit" "${BIN_DIR}/bandit" 2>/dev/null || true
    local ver; ver=$("${VENV_DIR}/bin/bandit" --version 2>/dev/null | head -1)
    log_ok "Bandit installed: ${ver}"
}

install_checkov() {
    log_step "Installing Checkov"
    source "${VENV_DIR}/bin/activate"
    pip install --quiet --upgrade checkov
    ln -sf "${VENV_DIR}/bin/checkov" "${BIN_DIR}/checkov" 2>/dev/null || true
    local ver; ver=$("${VENV_DIR}/bin/checkov" --version 2>/dev/null | head -1)
    log_ok "Checkov installed: ${ver}"
}

# ── Binary tools ──────────────────────────────────────────────────────────────

install_gitleaks() {
    log_step "Installing Gitleaks"
    local arch; arch=$(arch_name)
    local tag; tag=$(get_latest_gh_release "gitleaks/gitleaks")
    [[ -z "${tag}" ]] && tag="v8.18.4"
    local ver="${tag#v}"
    local url="https://github.com/gitleaks/gitleaks/releases/download/${tag}/gitleaks_${ver}_linux_${arch}.tar.gz"
    local tmp; tmp=$(mktemp -d)

    log_info "Downloading Gitleaks ${tag} (${arch})..."
    if curl -fsSL "${url}" | tar -xz -C "${tmp}" 2>/dev/null; then
        install -m 755 "${tmp}/gitleaks" "${BIN_DIR}/gitleaks"
        rm -rf "${tmp}"
        log_ok "Gitleaks installed: $("${BIN_DIR}/gitleaks" version 2>/dev/null | head -1)"
    else
        log_warn "Failed to download Gitleaks — skipping"
        rm -rf "${tmp}"
    fi
}

install_trivy() {
    log_step "Installing Trivy"
    local arch; arch=$(arch_name)
    local tag; tag=$(get_latest_gh_release "aquasecurity/trivy")
    [[ -z "${tag}" ]] && tag="v0.52.2"
    local ver="${tag#v}"
    local url="https://github.com/aquasecurity/trivy/releases/download/${tag}/trivy_${ver}_Linux-64bit.tar.gz"
    [[ "${arch}" == "arm64" ]] && url="https://github.com/aquasecurity/trivy/releases/download/${tag}/trivy_${ver}_Linux-ARM64.tar.gz"
    local tmp; tmp=$(mktemp -d)

    log_info "Downloading Trivy ${tag}..."
    if curl -fsSL "${url}" | tar -xz -C "${tmp}" 2>/dev/null; then
        install -m 755 "${tmp}/trivy" "${BIN_DIR}/trivy"
        rm -rf "${tmp}"
        log_ok "Trivy installed: $("${BIN_DIR}/trivy" --version 2>/dev/null | head -1)"
        log_info "Updating Trivy vulnerability database..."
        "${BIN_DIR}/trivy" image --download-db-only --quiet 2>/dev/null || true
        log_ok "Trivy DB updated"
    else
        log_warn "Failed to download Trivy — skipping"
        rm -rf "${tmp}"
    fi
}

install_dependency_check() {
    log_step "Installing OWASP Dependency Check"
    local dc_dir="${TOOLS_DIR}/dependency-check"
    local tag; tag=$(get_latest_gh_release "jeremylong/DependencyCheck")
    [[ -z "${tag}" ]] && tag="v9.2.0"
    local ver="${tag#v}"
    local url="https://github.com/jeremylong/DependencyCheck/releases/download/${tag}/dependency-check-${ver}-release.zip"
    local tmp; tmp=$(mktemp -d)

    log_info "Downloading OWASP Dependency Check ${tag}..."
    if curl -fsSL -o "${tmp}/dc.zip" "${url}" 2>/dev/null && \
       unzip -q "${tmp}/dc.zip" -d "${tmp}" 2>/dev/null; then
        rm -rf "${dc_dir}"
        mv "${tmp}/dependency-check" "${dc_dir}"
        chmod +x "${dc_dir}/bin/dependency-check.sh"
        rm -rf "${tmp}"
        log_ok "OWASP Dependency Check installed: ${dc_dir}"
        log_info "Downloading NVD vulnerability database (this may take several minutes)..."
        if [[ -n "${NVD_API_KEY}" ]]; then
            log_info "Using NVD API key for faster download (50 req/30s vs 5 req/30s)"
            "${dc_dir}/bin/dependency-check.sh" --updateonly --nvdApiKey "${NVD_API_KEY}" 2>/dev/null || true
        else
            log_warn "No NVD API key provided — download will be rate-limited (~5 req/30s, may take 30+ min)"
            log_warn "Get a free key at: https://nvd.nist.gov/developers/request-an-api-key"
            log_warn "Then rerun: sudo ./install --nvd-api-key <YOUR_KEY>"
            "${dc_dir}/bin/dependency-check.sh" --updateonly 2>/dev/null || true
        fi
        log_ok "NVD database update attempted"
        # Update the RetireJS vulnerability database (used for JS file scanning).
        # The bundled jsrepository.json is minimal; the full database covers
        # hundreds of npm packages for in-file version detection.
        log_info "Updating RetireJS vulnerability database..."
        "${dc_dir}/bin/dependency-check.sh" --noupdate --retireJsForceUpdate \
            --scan /dev/null --out /dev/null 2>/dev/null || true
        log_ok "RetireJS database updated"
        # Make the data directory world-writable so non-root users can open
        # the H2 database (dependency-check needs write access even with --noupdate)
        chmod -R a+rw "${dc_dir}/data/" 2>/dev/null || true
    else
        log_warn "Failed to download OWASP Dependency Check — skipping"
        rm -rf "${tmp}"
    fi
}

install_codeql() {
    log_step "Installing CodeQL"
    local codeql_dir="${TOOLS_DIR}/codeql"
    local tag; tag=$(get_latest_gh_release "github/codeql-action")
    [[ -z "${tag}" ]] && tag="codeql-bundle-v2.17.6"
    # Use the bundle tag for download
    local bundle_ver
    bundle_ver=$(curl -fsSL "https://api.github.com/repos/github/codeql-action/releases/latest" 2>/dev/null \
        | grep '"tag_name"' | grep "codeql-bundle" | head -1 \
        | sed 's/.*"tag_name":\s*"\([^"]*\)".*/\1/')
    [[ -z "${bundle_ver}" ]] && bundle_ver="codeql-bundle-v2.17.6"

    local url="https://github.com/github/codeql-action/releases/download/${bundle_ver}/codeql-bundle-linux64.tar.gz"
    local tmp; tmp=$(mktemp -d)

    log_info "Downloading CodeQL bundle ${bundle_ver} (~500MB, this will take a while)..."
    if curl -fsSL --progress-bar -o "${tmp}/codeql.tar.gz" "${url}" 2>/dev/null; then
        tar -xzf "${tmp}/codeql.tar.gz" -C "${tmp}" 2>/dev/null
        rm -rf "${codeql_dir}"
        mv "${tmp}/codeql" "${codeql_dir}"
        rm -rf "${tmp}"
        log_ok "CodeQL installed: $("${codeql_dir}/codeql" version --format=terse 2>/dev/null | head -1)"
    else
        log_warn "Failed to download CodeQL bundle — skipping (large download required)"
        rm -rf "${tmp}"
    fi
}

install_yara() {
    log_step "Installing YARA"

    # Try package manager first
    if   [[ "${OS}" == "debian" ]]; then
        if apt-get install -y -q yara 2>/dev/null; then
            log_ok "YARA installed via apt: $(yara --version 2>/dev/null)"
            return
        fi
    elif [[ "${OS}" == "rhel" ]]; then
        if yum install -y yara 2>/dev/null || dnf install -y yara 2>/dev/null; then
            log_ok "YARA installed via yum/dnf"
            return
        fi
    fi

    # Build from source
    log_info "Building YARA from source..."
    local tag; tag=$(get_latest_gh_release "VirusTotal/yara")
    [[ -z "${tag}" ]] && tag="v4.5.2"
    local ver="${tag#v}"
    local url="https://github.com/VirusTotal/yara/archive/refs/tags/${tag}.tar.gz"
    local tmp; tmp=$(mktemp -d)

    if curl -fsSL "${url}" | tar -xz -C "${tmp}" 2>/dev/null; then
        cd "${tmp}/yara-${ver}"
        ./bootstrap.sh 2>/dev/null
        ./configure --prefix="${TOOLS_DIR}" 2>/dev/null
        make -j"$(nproc)" 2>/dev/null
        make install 2>/dev/null
        cd - > /dev/null
        rm -rf "${tmp}"
        log_ok "YARA built and installed: $("${BIN_DIR}/yara" --version 2>/dev/null || yara --version 2>/dev/null)"
    else
        log_warn "Failed to build YARA from source"
        rm -rf "${tmp}"
    fi
}

# ── Rules & Templates ─────────────────────────────────────────────────────────

install_semgrep_rules() {
    log_step "Downloading Semgrep rules"
    local rules_dest="${RULES_DIR}/semgrep"

    # Download official semgrep rules via git (sparse checkout of security rules)
    if [[ -d "${rules_dest}/.git" ]]; then
        log_info "Updating existing Semgrep rules..."
        git -C "${rules_dest}" pull --quiet 2>/dev/null || true
    else
        log_info "Cloning Semgrep rules repository..."
        git clone --depth=1 --quiet \
            "https://github.com/returntocorp/semgrep-rules.git" \
            "${rules_dest}" 2>/dev/null || \
        git clone --depth=1 --quiet \
            "https://github.com/semgrep/semgrep-rules.git" \
            "${rules_dest}" 2>/dev/null || {
            log_warn "Could not clone semgrep-rules — will use 'auto' config"
        }
    fi
    # Remove non-rule files that semgrep would try to parse as rule YAML
    rm -rf "${rules_dest}/.github" "${rules_dest}/.git"
    log_ok "Semgrep rules ready: ${rules_dest}"
}

install_yara_rules() {
    log_step "Downloading YARA rules"
    local rules_dest="${RULES_DIR}/yara"

    if [[ -d "${rules_dest}/.git" ]]; then
        log_info "Updating existing YARA rules..."
        git -C "${rules_dest}" pull --quiet 2>/dev/null || true
    else
        log_info "Cloning YARA rules repositories..."
        # Community YARA rules
        git clone --depth=1 --quiet \
            "https://github.com/Yara-Rules/rules.git" \
            "${rules_dest}/yara-rules" 2>/dev/null || true
        # Additional malware rules
        git clone --depth=1 --quiet \
            "https://github.com/Neo23x0/signature-base.git" \
            "${rules_dest}/signature-base" 2>/dev/null || true
    fi

    # Flatten .yar files to rules root for easy scanning
    find "${rules_dest}" -name "*.yar" -o -name "*.yara" 2>/dev/null | head -200 | while read -r f; do
        local bn; bn=$(basename "${f}")
        [[ ! -f "${rules_dest}/${bn}" ]] && cp "${f}" "${rules_dest}/${bn}" 2>/dev/null || true
    done

    log_ok "YARA rules ready: ${rules_dest}"
}

# ── Copy lib files ────────────────────────────────────────────────────────────

install_lib_files() {
    log_step "Installing library files"
    if [[ -d "${LIB_SRC}" ]]; then
        cp -r "${LIB_SRC}/." "${TOOLS_DIR}/lib/"
        log_ok "Library files installed to ${TOOLS_DIR}/lib/"
    else
        log_warn "lib/ directory not found alongside installer — skipping"
    fi
}

# ── PATH symlinks ─────────────────────────────────────────────────────────────

create_symlinks() {
    log_step "Creating system-wide symlinks"
    local script_dir; script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    # sastscan main binary
    if [[ -f "${script_dir}/sastscan" ]]; then
        ln -sf "${script_dir}/sastscan" /usr/local/bin/sastscan
        chmod +x "${script_dir}/sastscan"
        log_ok "Symlink: /usr/local/bin/sastscan → ${script_dir}/sastscan"
    fi

    # Tool binaries
    for t in semgrep bandit checkov gitleaks trivy yara; do
        local bin_path="${BIN_DIR}/${t}"
        if [[ -x "${bin_path}" ]]; then
            ln -sf "${bin_path}" "/usr/local/bin/${t}" 2>/dev/null || true
            log_ok "Symlink: /usr/local/bin/${t}"
        fi
    done

    # Add TOOLS_DIR/bin to PATH profile
    local profile_d="/etc/profile.d/sastscan.sh"
    cat > "${profile_d}" << PROFILE
# sastscan tool PATH additions
export PATH="\$PATH:${BIN_DIR}"
PROFILE
    log_ok "PATH profile created: ${profile_d}"
}

# ── Verify installation ───────────────────────────────────────────────────────

verify_installation() {
    log_step "Verifying installations"
    echo ""

    local tools=(semgrep bandit checkov)
    local bins=(gitleaks trivy yara)

    printf "  %-30s %s\n" "Tool" "Status"
    printf "  %-30s %s\n" "────────────────────────────" "──────────────────────"

    for t in "${tools[@]}"; do
        if "${VENV_DIR}/bin/${t}" --version &>/dev/null || \
           command -v "${t}" &>/dev/null; then
            printf "  ${GREEN}%-30s${NC} %s\n" "${t}" "INSTALLED"
        else
            printf "  ${YELLOW}%-30s${NC} %s\n" "${t}" "NOT FOUND"
        fi
    done

    for b in "${bins[@]}"; do
        if [[ -x "${BIN_DIR}/${b}" ]] || command -v "${b}" &>/dev/null; then
            printf "  ${GREEN}%-30s${NC} %s\n" "${b}" "INSTALLED"
        else
            printf "  ${YELLOW}%-30s${NC} %s\n" "${b}" "NOT FOUND"
        fi
    done

    # Special checks
    for special in "dependency-check:${TOOLS_DIR}/dependency-check/bin/dependency-check.sh" \
                   "codeql:${TOOLS_DIR}/codeql/codeql"; do
        local name="${special%%:*}"
        local path="${special#*:}"
        if [[ -x "${path}" ]]; then
            printf "  ${GREEN}%-30s${NC} %s\n" "${name}" "INSTALLED"
        else
            printf "  ${YELLOW}%-30s${NC} %s\n" "${name}" "NOT FOUND (optional)"
        fi
    done

    echo ""
    printf "  %-30s %s\n" "YARA rules" \
        "$(find "${RULES_DIR}/yara" -name "*.yar" 2>/dev/null | wc -l) rules"
    printf "  %-30s %s\n" "Semgrep rules" \
        "$(find "${RULES_DIR}/semgrep" -name "*.yaml" -o -name "*.yml" 2>/dev/null | wc -l) rules"

    echo ""
    echo -e "${BOLD}Installation path: ${TOOLS_DIR}${NC}"
    echo ""
}

# ── Usage ─────────────────────────────────────────────────────────────────────

show_usage() {
    echo ""
    echo -e "${BOLD}Appu Corporation SAST Scanner${NC}"
    echo ""
    echo    "  Usage:  sudo ./install [options]"
    echo ""
    echo -e "${BOLD}  Options${NC}"
    printf  "    %-30s %s\n"  "--skip-codeql"          "- Skip CodeQL bundle installation (~500 MB)."
    printf  "    %-30s %s\n"  "--skip-depcheck"        "- Skip OWASP Dependency Check installation."
    printf  "    %-30s %s\n"  "--tools-only"           "- Install tools only; skip rules download."
    printf  "    %-30s %s\n"  "--update-rules"         "- Update rules and vulnerability databases only."
    printf  "    %-30s %s\n"  "--nvd-api-key <key>"    "- NVD API key for faster database download."
    printf  "    %-30s %s\n"  "--version"              "- Provides version details."
    printf  "    %-30s %s\n"  "--help/-h"              "- Provides help menu details."
    echo ""
}

show_version() {
    echo "sastscan-install ${VERSION}"
    echo "sastscan Installer — MIT License"
}

# ── Main ──────────────────────────────────────────────────────────────────────

SKIP_CODEQL=false
SKIP_DEPCHECK=false
TOOLS_ONLY=false
UPDATE_RULES_ONLY=false
NVD_API_KEY="9f4831a6-2404-4c4f-8e14-79419878dd6a"

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --skip-codeql)    SKIP_CODEQL=true ;;
            --skip-depcheck)  SKIP_DEPCHECK=true ;;
            --tools-only)     TOOLS_ONLY=true ;;
            --update-rules)   UPDATE_RULES_ONLY=true ;;
            --nvd-api-key)    NVD_API_KEY="$2"; shift ;;
            --nvd-api-key=*)  NVD_API_KEY="${1#*=}" ;;
            --version)        show_version; exit 0 ;;
            -h|--help)        show_usage;   exit 0 ;;
            *) log_warn "Unknown option: $1" ;;
        esac
        shift
    done
}

main() {
    parse_args "$@"
    banner
    require_root
    detect_os

    if ${UPDATE_RULES_ONLY}; then
        log_info "Updating rules and templates only..."
        install_semgrep_rules
        install_yara_rules
        # Also update NVD DB if dependency-check is installed
        local dc_bin="${TOOLS_DIR}/dependency-check/bin/dependency-check.sh"
        if [[ -x "${dc_bin}" ]]; then
            log_step "Updating NVD vulnerability database"
            if [[ -n "${NVD_API_KEY}" ]]; then
                log_info "Using NVD API key for faster download"
                "${dc_bin}" --updateonly --nvdApiKey "${NVD_API_KEY}" 2>/dev/null || true
            else
                log_warn "No NVD API key — rate-limited update (pass --nvd-api-key <KEY> to speed up)"
                "${dc_bin}" --updateonly 2>/dev/null || true
            fi
            log_ok "NVD database updated"
            log_info "Updating RetireJS vulnerability database..."
            "${dc_bin}" --noupdate --retireJsForceUpdate \
                --scan /dev/null --out /dev/null 2>/dev/null || true
            log_ok "RetireJS database updated"
            chmod -R a+rw "${dc_dir}/data/" 2>/dev/null || true
        fi
        log_ok "Rules updated successfully"
        exit 0
    fi

    setup_dirs
    install_system_deps
    setup_venv

    log_step "Installing Python-based tools"
    install_semgrep
    install_bandit
    install_checkov

    log_step "Installing binary tools"
    install_gitleaks
    install_trivy
    ${SKIP_DEPCHECK} || install_dependency_check
    ${SKIP_CODEQL}   || install_codeql
    install_yara

    if ! ${TOOLS_ONLY}; then
        log_step "Downloading rules and templates"
        install_semgrep_rules
        install_yara_rules
    fi

    install_lib_files
    create_symlinks
    verify_installation

    echo -e "${BOLD}${GREEN}Installation complete!${NC}"
    echo ""
    echo "  Run a scan:   sastscan --zip <file.zip> --name <ScanName>"
    echo "  Update rules: sudo ./install --update-rules"
    echo ""
}

main "$@"

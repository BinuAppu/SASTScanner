#!/usr/bin/env bash
# =============================================================================
#  sastscan uninstaller — removes everything installed by ./install
#  Version : 1.0.0
#  License : MIT
# =============================================================================

set -uo pipefail

VERSION="1.0.0"
TOOLS_DIR="/opt/tools/SASTScanner"
BIN_DIR="${TOOLS_DIR}/bin"
VENV_DIR="${TOOLS_DIR}/venv"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'; DIM='\033[2m'

ts()        { date '+%H:%M:%S'; }
log_info()  { echo -e "${BLUE}[INFO]${NC}    $(ts) │ $*"; }
log_ok()    { echo -e "${GREEN}[OK]${NC}      $(ts) │ $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}    $(ts) │ $*"; }
log_error() { echo -e "${RED}[ERROR]${NC}   $(ts) │ $*" >&2; }
log_skip()  { echo -e "${DIM}[SKIP]${NC}    $(ts) │ $*"; }
log_step()  { echo -e "\n${BOLD}${CYAN}── $* ${NC}"; }
log_dry()   { echo -e "${DIM}[DRY-RUN]${NC} $(ts) │ would remove: $*"; }

# ── Flags ─────────────────────────────────────────────────────────────────────
YES=false
KEEP_NVD=false
PURGE=false
DRY_RUN=false

# ── Helpers ───────────────────────────────────────────────────────────────────

banner() {
    echo ""
    echo -e "${BOLD}${RED}╔═══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${RED}║        sastscan Uninstaller  ─  Version ${VERSION}                 ║${NC}"
    echo -e "${BOLD}${RED}║        Removing tools from: ${TOOLS_DIR}      ║${NC}"
    echo -e "${BOLD}${RED}╚═══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "This uninstaller must be run as root (use sudo)"
        exit 1
    fi
}

# Safe remove — logs what it's doing; respects --dry-run
remove_path() {
    local target="$1"
    local label="${2:-${target}}"
    if [[ -e "${target}" || -L "${target}" ]]; then
        if ${DRY_RUN}; then
            log_dry "${label}"
        else
            rm -rf "${target}"
            log_ok "Removed: ${label}"
        fi
    else
        log_skip "Not found (already clean): ${label}"
    fi
}

remove_symlink() {
    local link="$1"
    if [[ -L "${link}" ]]; then
        if ${DRY_RUN}; then
            log_dry "symlink ${link} → $(readlink "${link}")"
        else
            rm -f "${link}"
            log_ok "Removed symlink: ${link}"
        fi
    else
        log_skip "Symlink not found: ${link}"
    fi
}

# ── Show what will be removed ─────────────────────────────────────────────────

show_inventory() {
    echo -e "${BOLD}The following will be removed:${NC}"
    echo ""

    # Tools directory
    if [[ -d "${TOOLS_DIR}" ]]; then
        local size; size=$(du -sh "${TOOLS_DIR}" 2>/dev/null | cut -f1)
        echo -e "  ${RED}●${NC} ${TOOLS_DIR}/  (${size})"
        [[ -d "${TOOLS_DIR}/venv" ]]              && echo "      ├── venv/                  (Semgrep, Bandit, Checkov)"
        [[ -d "${TOOLS_DIR}/bin" ]]               && echo "      ├── bin/                   (Gitleaks, Trivy, YARA)"
        [[ -d "${TOOLS_DIR}/codeql" ]]            && echo "      ├── codeql/                (CodeQL bundle)"
        [[ -d "${TOOLS_DIR}/dependency-check" ]]  && echo "      ├── dependency-check/      (OWASP DC + NVD database)"
        [[ -d "${TOOLS_DIR}/rules" ]]             && echo "      ├── rules/                 (Semgrep + YARA rule sets)"
        [[ -d "${TOOLS_DIR}/lib" ]]               && echo "      └── lib/                   (Report generator)"
    else
        echo -e "  ${DIM}●${NC} ${TOOLS_DIR}/  (not found)"
    fi

    echo ""
    echo -e "  ${RED}●${NC} Symlinks in /usr/local/bin/"
    for sym in sastscan semgrep bandit checkov gitleaks trivy yara; do
        [[ -L "/usr/local/bin/${sym}" ]] && echo "      /usr/local/bin/${sym}"
    done

    echo ""
    [[ -f /etc/profile.d/sastscan.sh ]] && \
        echo -e "  ${RED}●${NC} /etc/profile.d/sastscan.sh  (PATH entry)"

    # User caches (NVD + Trivy)
    local caches=()
    for home_dir in /root /home/*; do
        [[ -d "${home_dir}/.cache/sastscan" ]] && caches+=("${home_dir}/.cache/sastscan")
        [[ -d "${home_dir}/.cache/trivy"    ]] && caches+=("${home_dir}/.cache/trivy")
    done
    if [[ ${#caches[@]} -gt 0 ]]; then
        echo ""
        echo -e "  ${RED}●${NC} User cache directories (NVD / Trivy):"
        for c in "${caches[@]}"; do
            local cs; cs=$(du -sh "${c}" 2>/dev/null | cut -f1)
            local note=""
            [[ "${c}" == *"/sastscan" ]] && ${KEEP_NVD} && note=" ${DIM}(--keep-nvd: preserved)${NC}"
            echo -e "      ${c}  (${cs})${note}"
        done
    fi

    if ${PURGE}; then
        echo ""
        local script_dir; script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
        echo -e "  ${RED}●${NC} Script directory (--purge): ${script_dir}/"
        echo "      sastscan, install, uninstall"
    fi

    echo ""
}

# ── Uninstall steps ───────────────────────────────────────────────────────────

remove_tools_dir() {
    log_step "Removing tools directory"

    if ${KEEP_NVD} && [[ -f "${TOOLS_DIR}/dependency-check/data/odc.mv.db" ]]; then
        # Preserve only the NVD database; remove everything else
        local nvd_tmp; nvd_tmp=$(mktemp -d)
        log_info "--keep-nvd: preserving NVD database..."
        if ! ${DRY_RUN}; then
            cp -a "${TOOLS_DIR}/dependency-check/data/." "${nvd_tmp}/" 2>/dev/null || true
        fi
        remove_path "${TOOLS_DIR}" "TOOLS_DIR (${TOOLS_DIR})"
        if ! ${DRY_RUN}; then
            mkdir -p "${TOOLS_DIR}/dependency-check/data"
            cp -a "${nvd_tmp}/." "${TOOLS_DIR}/dependency-check/data/" 2>/dev/null || true
            rm -rf "${nvd_tmp}"
            log_ok "NVD database preserved at ${TOOLS_DIR}/dependency-check/data/"
        fi
    else
        remove_path "${TOOLS_DIR}" "TOOLS_DIR (${TOOLS_DIR})"
    fi
}

remove_symlinks() {
    log_step "Removing /usr/local/bin symlinks"
    for sym in sastscan semgrep bandit checkov gitleaks trivy yara; do
        remove_symlink "/usr/local/bin/${sym}"
    done
}

remove_profile() {
    log_step "Removing PATH profile"
    remove_path "/etc/profile.d/sastscan.sh" "/etc/profile.d/sastscan.sh"
}

remove_user_caches() {
    log_step "Removing user cache directories"
    local found=false

    for home_dir in /root /home/*; do
        # sastscan NVD cache
        local sast_cache="${home_dir}/.cache/sastscan"
        if [[ -d "${sast_cache}" ]]; then
            found=true
            if ${KEEP_NVD}; then
                log_skip "Preserving NVD cache (--keep-nvd): ${sast_cache}"
            else
                remove_path "${sast_cache}" "${sast_cache}"
            fi
        fi

        # Trivy vulnerability database cache
        local trivy_cache="${home_dir}/.cache/trivy"
        if [[ -d "${trivy_cache}" ]]; then
            found=true
            remove_path "${trivy_cache}" "${trivy_cache}"
        fi
    done

    ${found} || log_skip "No user caches found"
}

purge_scripts() {
    log_step "Purging sastscan scripts (--purge)"
    local script_dir; script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    for f in sastscan install uninstall; do
        remove_path "${script_dir}/${f}" "${script_dir}/${f}"
    done
    # Remove the lib/ directory alongside the scripts if it exists
    [[ -d "${script_dir}/lib" ]] && remove_path "${script_dir}/lib" "${script_dir}/lib/"
}

# ── Usage / Version ───────────────────────────────────────────────────────────

show_usage() {
    echo ""
    echo -e "${BOLD}Appu Corporation SAST Scanner${NC}"
    echo ""
    echo    "  Usage:  sudo ./uninstall [options]"
    echo ""
    echo -e "${BOLD}  Options${NC}"
    printf  "    %-30s %s\n"  "--yes/-y"               "- Skip confirmation prompt; uninstall immediately."
    printf  "    %-30s %s\n"  "--keep-nvd"             "- Preserve the NVD vulnerability database (~225 MB)."
    printf  "    %-30s %s\n"  "--purge"                "- Also remove the sastscan CLI scripts (complete wipe)."
    printf  "    %-30s %s\n"  "--dry-run"              "- Preview what would be removed without deleting anything."
    printf  "    %-30s %s\n"  "--version"              "- Provides version details."
    printf  "    %-30s %s\n"  "--help/-h"              "- Provides help menu details."
    echo ""
}

show_version() {
    echo "sastscan-uninstall ${VERSION}"
    echo "sastscan Uninstaller — MIT License"
}

# ── Argument Parsing ──────────────────────────────────────────────────────────

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -y|--yes)       YES=true      ;;
            --keep-nvd)     KEEP_NVD=true ;;
            --purge)        PURGE=true    ;;
            --dry-run)      DRY_RUN=true  ;;
            --version)      show_version; exit 0 ;;
            -h|--help)      show_usage;   exit 0 ;;
            *) log_warn "Unknown option: $1" ;;
        esac
        shift
    done
}

# ── Confirmation prompt ───────────────────────────────────────────────────────

confirm() {
    if ${YES}; then
        return 0
    fi
    echo -e "${YELLOW}${BOLD}WARNING:${NC} This will permanently delete all sastscan tools and data."
    ${KEEP_NVD} && echo -e "${DIM}         (NVD database will be preserved)${NC}"
    ${PURGE}    && echo -e "${RED}         (--purge: sastscan scripts will also be deleted)${NC}"
    echo ""
    read -rp "Type 'yes' to confirm: " answer
    if [[ "${answer}" != "yes" ]]; then
        echo "Aborted."
        exit 0
    fi
}

# ── Summary ───────────────────────────────────────────────────────────────────

show_summary() {
    echo ""
    echo -e "${BOLD}${GREEN}╔═══════════════════════════════════════════════════════════════╗${NC}"
    if ${DRY_RUN}; then
        echo -e "${BOLD}${GREEN}║          Dry-run complete — nothing was removed               ║${NC}"
    else
        echo -e "${BOLD}${GREEN}║          Uninstall complete                                   ║${NC}"
    fi
    echo -e "${BOLD}${GREEN}╚═══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    if ! ${DRY_RUN}; then
        echo "  To reinstall:  sudo ./install"
        ${KEEP_NVD} && echo "  NVD database preserved — reinstall will skip the 30-60 min download"
        echo ""
    fi
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
    parse_args "$@"
    banner
    require_root

    if ${DRY_RUN}; then
        log_warn "DRY-RUN mode — nothing will be deleted"
        echo ""
    fi

    show_inventory
    confirm

    remove_tools_dir
    remove_symlinks
    remove_profile
    remove_user_caches
    ${PURGE} && purge_scripts

    show_summary
}

main "$@"

    printf  "    %-32s %s\n"  ""                        "  Prompts for: URL, modelName, apiVersion, subscriptionKey, encKey."
    printf  "    %-32s %s\n"  ""                        "  Config saved encrypted to ~/.sastscan_ai_config."
    printf  "    %-32s %s\n"  "--useAI"                 "Enable AI-powered analysis after the scan.  Requires --encKey."
    printf  "    %-32s %s\n"  ""                        "  Sends top findings to the configured AI endpoint."

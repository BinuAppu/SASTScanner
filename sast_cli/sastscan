    printf  "    %-32s %s\n"  "--zip/-z <path>"         "Path to the .zip archive containing source code."
    printf  "    %-32s %s\n"  "--name/-n <name>"        "Label for this scan (used in output directory and report)."
    echo ""
    echo -e "${BOLD}  Options${NC}"
    printf  "    %-32s %s\n"  "--modules/-m <list>"     "Comma-separated modules to run, or 'all'.  Default: all."
    printf  "    %-32s %s\n"  ""                        "  Modules: semgrep, bandit, pattern, secrets, gitleaks,"
    printf  "    %-32s %s\n"  ""                        "           trivy, dependency_check, checkov, codeql, yara"
    printf  "    %-32s %s\n"  "--verbose/-v <bool>"     "Verbose output: true | false.  Default: true."
    printf  "    %-32s %s\n"  "--version"               "Print version and exit."
    printf  "    %-32s %s\n"  "--help/-h"               "Print this help and exit."

set -uo pipefail

VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLS_DIR="/opt/tools/SASTScanner"

# ── Locate lib dir ────────────────────────────────────────────────────────────
if   [[ -f "${SCRIPT_DIR}/lib/generate_report.py" ]]; then
    LIB_DIR="${SCRIPT_DIR}/lib"
elif [[ -f "${TOOLS_DIR}/lib/generate_report.py" ]]; then
    LIB_DIR="${TOOLS_DIR}/lib"
else
    LIB_DIR="${SCRIPT_DIR}/lib"   # best-effort fallback
fi

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; MAGENTA='\033[0;35m'
BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

# ── Defaults ──────────────────────────────────────────────────────────────────
VERBOSE=true
MODULES="all"
ZIP_FILE=""
SCAN_NAME=""
SCAN_DIR=""
EXTRACT_DIR=""
REPORT_DIR=""
DEBUG_DIR=""
ERROR_LOG=""
START_TS=0

ALL_MODULES=(semgrep bandit pattern secrets gitleaks trivy dependency_check checkov codeql yara)
SELECTED_MODULES=()
FAILED_MODULES=()
PASSED_MODULES=()
SKIPPED_MODULES=()

# ── AI Configuration ──────────────────────────────────────────────────────────
CONFIGURE_AI=false
USE_AI=false
ENC_KEY=""
AI_CONFIG_FILE="${HOME}/.sastscan_ai_config"

# ── Logging ───────────────────────────────────────────────────────────────────

log_banner() {
    echo ""
    echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${CYAN}║         SAST Scanner  ─  Static Application Security Testing         ║${NC}"
    echo -e "${BOLD}${CYAN}║                          Version ${VERSION}                              ║${NC}"
    echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

ts()         { date '+%H:%M:%S'; }
log_info()   { echo -e "${BLUE}[INFO]${NC}    $(ts) │ $*"; }
log_ok()     { echo -e "${GREEN}[OK]${NC}      $(ts) │ $*"; }
log_warn()   { echo -e "${YELLOW}[WARN]${NC}    $(ts) │ $*"; }
log_error()  { echo -e "${RED}[ERROR]${NC}   $(ts) │ $*" >&2; }
log_skip()   { echo -e "${DIM}[SKIP]${NC}    $(ts) │ $*"; }
log_mod()    { local m="${1^^}"; shift; printf "${MAGENTA}[%-17s]${NC} $(ts) │ %s\n" "${m}" "$*"; }
log_vb()     { [[ "${VERBOSE}" == "true" ]] && echo -e "${DIM}[VERBOSE]${NC} $(ts) │ $*" || true; }
log_sec()    {
    echo ""
    echo -e "${BOLD}${CYAN}──────────────────────────────────────────────────────────────────────${NC}"
    echo -e "${BOLD}${CYAN}  $*${NC}"
    echo -e "${BOLD}${CYAN}──────────────────────────────────────────────────────────────────────${NC}"
    echo ""
}

# ── Usage / Version ───────────────────────────────────────────────────────────


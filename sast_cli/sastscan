# ── Summary ───────────────────────────────────────────────────────────────────

print_summary() {
    local end_ts; end_ts=$(date +%s)
    local duration=$((end_ts - START_TS))
    local mins=$((duration / 60))
    local secs=$((duration % 60))

    # Count total findings across all CSVs (subtract header)
    local total_findings=0
    while IFS= read -r -d '' f; do
        local cnt; cnt=$(wc -l < "${f}")
        total_findings=$((total_findings + cnt - 1))
    done < <(find "${REPORT_DIR}" -name "*.csv" -print0 2>/dev/null)

    echo ""
    echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${CYAN}║                        SCAN SUMMARY                                  ║${NC}"
    echo -e "${BOLD}${CYAN}╠══════════════════════════════════════════════════════════════════════╣${NC}"
    printf "${BOLD}${CYAN}║${NC}  %-35s %-32s ${BOLD}${CYAN}║${NC}\n" "Scan Name:"  "${SCAN_NAME}"
    printf "${BOLD}${CYAN}║${NC}  %-35s %-32s ${BOLD}${CYAN}║${NC}\n" "Workspace:"  "${SCAN_DIR}"
    printf "${BOLD}${CYAN}║${NC}  %-35s %-32s ${BOLD}${CYAN}║${NC}\n" "Duration:"   "${mins}m ${secs}s"
    printf "${BOLD}${CYAN}║${NC}  %-35s %-32s ${BOLD}${CYAN}║${NC}\n" "Total Findings:" "${total_findings}"
    echo -e "${BOLD}${CYAN}╠══════════════════════════════════════════════════════════════════════╣${NC}"

    if [[ ${#PASSED_MODULES[@]} -gt 0 ]]; then
        printf "${BOLD}${CYAN}║${NC}  ${GREEN}%-35s${NC} %-32s ${BOLD}${CYAN}║${NC}\n" \
            "Passed Modules (${#PASSED_MODULES[@]}):" "$(IFS=', '; echo "${PASSED_MODULES[*]}")"
    fi
    if [[ ${#SKIPPED_MODULES[@]} -gt 0 ]]; then
        printf "${BOLD}${CYAN}║${NC}  ${YELLOW}%-35s${NC} %-32s ${BOLD}${CYAN}║${NC}\n" \
            "Skipped Modules (${#SKIPPED_MODULES[@]}):" "$(IFS=', '; echo "${SKIPPED_MODULES[*]}")"
    fi
    if [[ ${#FAILED_MODULES[@]} -gt 0 ]]; then
        printf "${BOLD}${CYAN}║${NC}  ${RED}%-35s${NC} %-32s ${BOLD}${CYAN}║${NC}\n" \
            "Failed Modules (${#FAILED_MODULES[@]}):" "$(IFS=', '; echo "${FAILED_MODULES[*]}")"
    fi

    echo -e "${BOLD}${CYAN}╠══════════════════════════════════════════════════════════════════════╣${NC}"
    echo -e "${BOLD}${CYAN}║${NC}  Reports:  ${REPORT_DIR}/"
    echo -e "${BOLD}${CYAN}║${NC}  HTML:     ${REPORT_DIR}/report.html"
    echo -e "${BOLD}${CYAN}║${NC}  Debug:    ${ERROR_LOG}"
    echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
    START_TS=$(date +%s)

    parse_args "$@"
    log_banner

    # --ConfigureAI is a standalone interactive setup — no scan needed
    if [[ "${CONFIGURE_AI}" == "true" ]]; then
        configure_ai
        exit 0
    fi

    validate_inputs
    resolve_modules

    log_info "Scan Name    : ${SCAN_NAME}"
    log_info "ZIP File     : ${ZIP_FILE}"
    log_info "Modules      : $(IFS=', '; echo "${SELECTED_MODULES[*]}")"
    log_info "Verbose      : ${VERBOSE}"
    [[ "${USE_AI}" == "true" ]] && log_info "AI Analysis  : enabled"

    log_sec "Setting Up Scan Environment"
    setup_dirs
    extract_zip

    log_sec "Running Security Modules"
    local total="${#SELECTED_MODULES[@]}"
    local idx=0
    for mod in "${SELECTED_MODULES[@]}"; do
        ((idx++))
        echo ""
        echo -e "${BOLD}[${idx}/${total}] Module: ${mod^^}${NC}"
        echo -e "${DIM}────────────────────────────────────────────${NC}"
        run_module "${mod}" || {
            log_warn "Module '${mod}' encountered an error"
            echo "[${mod^^}] Unexpected error in module runner" >> "${ERROR_LOG}"
        }
    done

    if [[ "${USE_AI}" == "true" ]]; then
        run_ai_scan || log_warn "AI scan did not complete successfully"
    fi

    generate_html_report
    print_summary
}

main "$@"

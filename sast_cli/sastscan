            fix   = f"Upgrade {pkg} to {v.get('FixedVersion','latest')}"
            cwe   = ", ".join(v.get("CweIDs",[]))
            wr.writerow(["Trivy",target,"",sev,vid,"vulnerability",title,f"{desc} [CVSS:{cvss}]",cwe,fix])
            rows+=1
        for m in res.get("Misconfigurations",[]):
            mid   = m.get("ID","")
            sev   = SEV_MAP.get(m.get("Severity","MEDIUM").upper(),"MEDIUM")
            title = m.get("Title","")
            desc  = (m.get("Description","") or "").replace("\n"," ")[:300]
            fix   = m.get("Resolution","Review configuration")
            wr.writerow(["Trivy",target,"",sev,mid,"misconfiguration",title,desc,"",fix])
            rows+=1

print(rows,end="")
PYEOF
    )
    log_ok "Trivy complete — ${count} finding(s)"
    PASSED_MODULES+=(trivy)
}

# ── MODULE: Dependency Check ──────────────────────────────────────────────────

run_dependency_check() {
    local csv="${REPORT_DIR}/dependency_check.csv"
    local raw="${DEBUG_DIR}/dependency_check_raw.json"
    local dc_dir="${TOOLS_DIR}/dependency-check"
    log_mod "dependency_check" "Starting OWASP Dependency Check scan..."
    csv_header "${csv}"

    local bin="${dc_dir}/bin/dependency-check.sh"
    if [[ ! -x "${bin}" ]]; then
        log_skip "OWASP Dependency Check not installed — run './install' first"
        echo "[DEPENDENCY-CHECK] Not installed" >> "${ERROR_LOG}"
        SKIPPED_MODULES+=(dependency_check); return
    fi

    log_vb "Binary: ${bin}"

    # H2 requires write access to odc.mv.db; if the shared data dir is root-owned,
    # keep a persistent user-owned copy and point --data at it instead.
    local dc_extra_args=()
    if [[ ! -w "${dc_dir}/data/odc.mv.db" ]]; then
        local dc_user_data="${HOME}/.cache/sastscan/dc_data"
        if [[ ! -f "${dc_user_data}/odc.mv.db" ]] || \
           [[ "${dc_dir}/data/odc.mv.db" -nt "${dc_user_data}/odc.mv.db" ]]; then
            log_vb "NVD database not writable — copying to user cache (first run may take ~30s)..."
            mkdir -p "${dc_user_data}"
            cp -a "${dc_dir}/data/." "${dc_user_data}/" 2>>"${ERROR_LOG}"
        fi
        dc_extra_args+=(--data "${dc_user_data}")
    fi

    "${bin}" \
        --scan "${EXTRACT_DIR}" \
        --format JSON \
        --out "${DEBUG_DIR}/dc_report" \
        --project "${SCAN_NAME}" \
        --noupdate \
        --disableAssembly \
        "${dc_extra_args[@]}" \
        >> "${ERROR_LOG}" 2>&1 || true

    local json_out="${DEBUG_DIR}/dc_report/dependency-check-report.json"
    if [[ ! -f "${json_out}" ]]; then
        log_warn "Dependency Check produced no JSON output"
        FAILED_MODULES+=(dependency_check); return
    fi

    cp "${json_out}" "${raw}"

    local dc_count
    dc_count=$(python3 - "${raw}" "${csv}" << 'PYEOF'
import json,sys,csv as csvmod,os

raw,out_csv=sys.argv[1],sys.argv[2]
rows=0

with open(raw,'r',errors='replace') as fh:
    try: data=json.load(fh)
    except: print("0",end=""); sys.exit(0)

deps=data.get("dependencies",[])

with open(out_csv,'a',newline='',encoding='utf-8') as fh:
    wr=csvmod.writer(fh,quoting=csvmod.QUOTE_ALL)
    for dep in deps:
        fname=dep.get("fileName","")
        for vuln in dep.get("vulnerabilities",[]):
            vid   = vuln.get("name","")
            sev   = vuln.get("severity","MEDIUM").upper()
            desc  = (vuln.get("description","") or "").replace("\n"," ")[:300]
            cvss  = str(vuln.get("cvssv3",{}).get("baseScore","") or vuln.get("cvssv2",{}).get("score",""))
            cwe   = vuln.get("cwes",[""])[0] if vuln.get("cwes") else ""
            title = f"CVE in {os.path.basename(fname)}" if fname else vid
            fix   = vuln.get("solution","Update to patched version") or "Update to patched version"
            wr.writerow(["DependencyCheck",fname,"",sev,vid,"dependency-vulnerability",vid,f"{desc} [CVSS:{cvss}]",cwe,fix])
            rows+=1

print(rows,end="")
PYEOF
    )

    # ── npm / Node.js: query OSV API for each package.json found ────────────────
    # OWASP DC's NVD database has poor CPE coverage for npm packages.
    # The OSV API (osv.dev) is authoritative for npm CVEs and requires no
    # local tooling — only a package.json and network access.
    local npm_count=0
    while IFS= read -r -d '' pkgjson; do
        [[ -s "${pkgjson}" ]] || continue
        log_vb "npm OSV scan: $(basename "$(dirname "${pkgjson}")")/package.json"
        local n
        n=$(python3 - "${pkgjson}" "${csv}" "${EXTRACT_DIR}" 2>>"${ERROR_LOG}" << 'NPM_OSV_EOF'
import json, sys, csv as csvmod, re
import urllib.request, urllib.error
from concurrent.futures import ThreadPoolExecutor, as_completed

pkgjson_path = sys.argv[1]
out_csv      = sys.argv[2]
base         = sys.argv[3].rstrip("/")

try:
    with open(pkgjson_path) as f:
        pkg = json.load(f)
except Exception as e:
    print(f"[OSV] parse error: {e}", file=sys.stderr)
    print("0", end=""); sys.exit(0)

deps = {}
deps.update(pkg.get("dependencies", {}))
deps.update(pkg.get("devDependencies", {}))

if not deps:
    print("0", end=""); sys.exit(0)

queries  = []
pkg_info = []

for name, ver_spec in deps.items():
    ver = ver_spec.strip()
    m = re.search(r'\d+\.\d+[\.\d]*', ver)
    if not m or "://" in ver or ver.startswith("git"):
        continue
    ver = m.group(0)
    queries.append({"version": ver, "package": {"name": name, "ecosystem": "npm"}})
    pkg_info.append((name, ver))

if not queries:
    print("0", end=""); sys.exit(0)

# Step 1: batch query — find which packages have known vulnerabilities
try:
    payload = json.dumps({"queries": queries}).encode()
    req = urllib.request.Request(
        "https://api.osv.dev/v1/querybatch",
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST"
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        batch = json.loads(resp.read())
except urllib.error.URLError as e:
    print(f"[OSV] Network error — npm scan skipped: {e}", file=sys.stderr)
    print("0", end=""); sys.exit(0)
except Exception as e:
    print(f"[OSV] Error: {e}", file=sys.stderr)
    print("0", end=""); sys.exit(0)

# Collect all GHSA/OSV IDs returned, mapped to their package
pending = {}   # osv_id → (pkg_name, pkg_ver)
for i, result in enumerate(batch.get("results", [])):
    if i >= len(pkg_info):
        break
    pkg_name, pkg_ver = pkg_info[i]
    for vuln in result.get("vulns", []):
        osv_id = vuln.get("id", "")
        if osv_id:
            pending[osv_id] = (pkg_name, pkg_ver)

if not pending:
    print("0", end=""); sys.exit(0)

# Step 2: fetch full vuln records in parallel to get CVE aliases + accurate severity
def fetch_vuln(osv_id):
    try:
        url = f"https://api.osv.dev/v1/vulns/{osv_id}"
        with urllib.request.urlopen(url, timeout=15) as r:
            return osv_id, json.loads(r.read())
    except Exception:
        return osv_id, {}

vuln_details = {}
with ThreadPoolExecutor(max_workers=10) as ex:
    for osv_id, detail in ex.map(fetch_vuln, pending.keys()):
        vuln_details[osv_id] = detail

SEV_MAP = {"CRITICAL":"CRITICAL","HIGH":"HIGH","MODERATE":"MEDIUM",
           "MEDIUM":"MEDIUM","LOW":"LOW"}
seen  = set()
rows  = 0
rel_path = pkgjson_path.replace(base + "/", "", 1)

with open(out_csv, "a", newline="", encoding="utf-8") as fh:
    wr = csvmod.writer(fh, quoting=csvmod.QUOTE_ALL)
    for osv_id, (pkg_name, pkg_ver) in pending.items():
        detail = vuln_details.get(osv_id, {})
        aliases = detail.get("aliases", [])
        # Prefer CVE ID; fall back to GHSA/OSV ID
        vid = next((a for a in aliases if a.startswith("CVE-")), osv_id)
        key = f"{pkg_name}:{vid}"
        if key in seen:
            continue
        seen.add(key)

        # Severity: prefer database_specific, fall back to HIGH for npm
        sev = "HIGH"
        db_sev = detail.get("database_specific", {}).get("severity", "")
        if db_sev:
            sev = SEV_MAP.get(db_sev.upper(), "HIGH")
        else:
            for aff in detail.get("affected", []):
                s = aff.get("database_specific", {}).get("severity", "")
                if s:
                    sev = SEV_MAP.get(s.upper(), "HIGH")
                    break

        title = (detail.get("summary", "") or vid)[:200]
        desc  = (detail.get("details",  "") or "").replace("\n", " ")[:300]
        cwes  = detail.get("database_specific", {}).get("cwe_ids", [])
        cwe   = "; ".join(cwes)
        fix   = f"Update {pkg_name} (currently {pkg_ver}) to a patched version"

        wr.writerow([
            "DependencyCheck", rel_path, "", sev, vid,
            "dependency-vulnerability", title,
            f"{desc} [npm:{pkg_name}@{pkg_ver}]"[:300],
            cwe, fix
        ])
        rows += 1

print(rows, end="")
NPM_OSV_EOF
        ) || true
        npm_count=$(( npm_count + ${n:-0} ))
    done < <(find "${EXTRACT_DIR}" -name "package.json" \
        -not -path "*/node_modules/*" -print0 2>/dev/null)

    local total=$(( ${dc_count:-0} + npm_count ))
    log_ok "Dependency Check complete — ${total} finding(s) (DC:${dc_count:-0} npm-OSV:${npm_count})"
    PASSED_MODULES+=(dependency_check)
}


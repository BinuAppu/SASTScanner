# ── MODULE: Gitleaks ──────────────────────────────────────────────────────────

run_gitleaks() {
    local csv="${REPORT_DIR}/gitleaks.csv"
    local raw="${DEBUG_DIR}/gitleaks_raw.json"
    log_mod "gitleaks" "Starting git secrets scan..."
    csv_header "${csv}"

    local bin; bin=$(tool_path gitleaks)
    if [[ -z "${bin}" ]]; then
        log_skip "Gitleaks not installed — run './install' first"
        echo "[GITLEAKS] Not installed" >> "${ERROR_LOG}"
        SKIPPED_MODULES+=(gitleaks); return
    fi

    log_vb "Binary: ${bin}"

    "${bin}" detect --source="${EXTRACT_DIR}" \
        --report-format=json --report-path="${raw}" \
        --no-git --exit-code 0 \
        2>>"${ERROR_LOG}" || true

    if [[ ! -s "${raw}" ]]; then
        log_ok "Gitleaks — no secrets found (or non-git source)"
        echo "Gitleaks" > /dev/null
        csv_row "${csv}" "Gitleaks" "" "" "INFO" "" "" "No secrets detected" "" "" ""
        PASSED_MODULES+=(gitleaks); return
    fi

    local count
    count=$(python3 - "${raw}" "${csv}" "${EXTRACT_DIR}" << 'PYEOF'
import json,sys,csv as csvmod

raw,out_csv,base=sys.argv[1],sys.argv[2],sys.argv[3]
rows=0

with open(raw,'r',errors='replace') as fh:
    try: data=json.load(fh)
    except: print("0",end=""); sys.exit(0)

if not isinstance(data,list): data=[]

with open(out_csv,'a',newline='',encoding='utf-8') as fh:
    wr=csvmod.writer(fh,quoting=csvmod.QUOTE_ALL)
    for r in data:
        path  = r.get("File","").replace(base.rstrip("/")+"/","")
        line  = str(r.get("StartLine",""))
        rid   = r.get("RuleID","")
        title = r.get("Description","Gitleaks Finding")
        sev   = "HIGH"
        desc  = f"Secret match for rule '{rid}' — value redacted"
        wr.writerow(["Gitleaks",path,line,sev,rid,"secret-detection",title,desc,"CWE-798","Rotate credential; remove from source"])
        rows+=1

print(rows,end="")
PYEOF
    )
    log_ok "Gitleaks complete — ${count} finding(s)"
    PASSED_MODULES+=(gitleaks)
}


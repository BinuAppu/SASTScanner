run_checkov() {
    local csv="${REPORT_DIR}/checkov.csv"
    local raw="${DEBUG_DIR}/checkov_raw.json"
    log_mod "checkov" "Starting IaC security scan..."
    csv_header "${csv}"

    local bin; bin=$(tool_path checkov)
    if [[ -z "${bin}" ]]; then
        log_skip "Checkov not installed — run './install' first"
        echo "[CHECKOV] Not installed" >> "${ERROR_LOG}"
        SKIPPED_MODULES+=(checkov); return
    fi

    log_vb "Binary: ${bin}"

    "${bin}" -d "${EXTRACT_DIR}" \
        -o json --output-file-path "${DEBUG_DIR}" \
        --quiet --compact \
        2>>"${ERROR_LOG}" || true

    # Checkov writes results.json to output directory
    local json_out="${DEBUG_DIR}/results_json.json"
    [[ ! -f "${json_out}" ]] && json_out="${DEBUG_DIR}/checkov_results.json"

    # Try running with stdout capture if file not found
    if [[ ! -f "${json_out}" ]]; then
        "${bin}" -d "${EXTRACT_DIR}" -o json --quiet --compact > "${raw}" 2>>"${ERROR_LOG}" || true
        json_out="${raw}"
    fi

    if [[ ! -s "${json_out}" ]]; then
        log_warn "Checkov produced no output"
        FAILED_MODULES+=(checkov); return
    fi

    cp "${json_out}" "${raw}" 2>/dev/null || true

    local count
    count=$(python3 - "${raw}" "${csv}" "${EXTRACT_DIR}" << 'PYEOF'
import json,sys,csv as csvmod

raw,out_csv,base=sys.argv[1],sys.argv[2],sys.argv[3]
rows=0

with open(raw,'r',errors='replace') as fh:
    try: content=fh.read().strip()
    except: print("0",end=""); sys.exit(0)

# Checkov can output multiple JSON objects concatenated
import re
objects=[]
try:
    # Try as single object or array
    data=json.loads(content)
    if isinstance(data,list): objects=data
    else: objects=[data]
except:
    # Try to extract JSON objects
    for chunk in re.split(r'\n(?=\{)',content):
        try: objects.append(json.loads(chunk))
        except: pass

with open(out_csv,'a',newline='',encoding='utf-8') as fh:
    wr=csvmod.writer(fh,quoting=csvmod.QUOTE_ALL)
    for obj in objects:
        results=obj.get("results",{}) if isinstance(obj,dict) else {}
        failed=results.get("failed_checks",[]) if results else []
        for r in failed:
            check=r.get("check",{}) if isinstance(r.get("check"),dict) else {}
            path =r.get("repo_file_path","") or r.get("file_path","")
            path =path.replace(base.rstrip("/")+"/","")
            line =str(r.get("file_line_range",[0])[0]) if r.get("file_line_range") else ""
            rid  =check.get("id","") or r.get("check_id","")
            title=check.get("name","") or r.get("check","")
            sev  =r.get("severity","MEDIUM") or "MEDIUM"
            if isinstance(sev,str): sev=sev.upper()
            else: sev="MEDIUM"
            wr.writerow(["Checkov",path,line,sev,rid,"iac-misconfiguration",title,f"IaC check failed: {rid}","",f"See Checkov docs for {rid}"])
            rows+=1

print(rows,end="")
PYEOF
    )
    log_ok "Checkov complete — ${count} finding(s)"
    PASSED_MODULES+=(checkov)
}

# ── MODULE: CodeQL ────────────────────────────────────────────────────────────

run_codeql() {
    local csv="${REPORT_DIR}/codeql.csv"
    local raw="${DEBUG_DIR}/codeql_raw.sarif"
    local codeql_dir="${TOOLS_DIR}/codeql"
    log_mod "codeql" "Starting CodeQL analysis..."
    csv_header "${csv}"

    local bin="${codeql_dir}/codeql"
    if [[ ! -x "${bin}" ]]; then
        log_skip "CodeQL not installed — run './install' first"
        echo "[CODEQL] Not installed" >> "${ERROR_LOG}"
        SKIPPED_MODULES+=(codeql); return
    fi

    local db_dir="${DEBUG_DIR}/codeql_db"
    local lang=""

    # Auto-detect primary language
    local py_c; py_c=$(find "${EXTRACT_DIR}" -name "*.py" 2>/dev/null | wc -l)
    local js_c; js_c=$(find "${EXTRACT_DIR}" -name "*.js" -o -name "*.ts" 2>/dev/null | wc -l)
    local java_c; java_c=$(find "${EXTRACT_DIR}" -name "*.java" 2>/dev/null | wc -l)
    local go_c; go_c=$(find "${EXTRACT_DIR}" -name "*.go" 2>/dev/null | wc -l)

    if   [[ ${py_c}   -gt 0 ]]; then lang="python"
    elif [[ ${js_c}   -gt 0 ]]; then lang="javascript"
    elif [[ ${java_c} -gt 0 ]]; then lang="java"
    elif [[ ${go_c}   -gt 0 ]]; then lang="go"
    else
        log_skip "CodeQL — no supported language files found (python/js/java/go)"
        SKIPPED_MODULES+=(codeql); return
    fi

    log_vb "Detected language: ${lang}"

    # Resolve the versioned .qls path (e.g. python-queries/1.8.0/codeql-suites/...)
    local qls_file
    qls_file=$(find "${codeql_dir}/qlpacks/codeql/${lang}-queries" \
        -name "${lang}-security-extended.qls" -path "*/codeql-suites/*" 2>/dev/null | head -1)
    if [[ -z "${qls_file}" ]]; then
        log_warn "CodeQL — query suite not found for language: ${lang}"
        echo "[CODEQL] Query suite missing: ${codeql_dir}/qlpacks/codeql/${lang}-queries/**/codeql-suites/${lang}-security-extended.qls" >> "${ERROR_LOG}"
        FAILED_MODULES+=(codeql); return
    fi
    log_vb "Query suite: ${qls_file}"
    log_vb "Creating CodeQL database (this may take a few minutes)..."

    "${bin}" database create "${db_dir}" \
        --language="${lang}" \
        --source-root="${EXTRACT_DIR}" \
        --overwrite \
        2>>"${ERROR_LOG}" || { log_warn "CodeQL database creation failed"; FAILED_MODULES+=(codeql); return; }

    log_vb "Running CodeQL analysis..."

    "${bin}" database analyze "${db_dir}" \
        --format=sarif-latest \
        --output="${raw}" \
        "${qls_file}" \
        2>>"${ERROR_LOG}" || { log_warn "CodeQL analysis failed"; FAILED_MODULES+=(codeql); return; }

    if [[ ! -s "${raw}" ]]; then
        log_warn "CodeQL produced no SARIF output"
        FAILED_MODULES+=(codeql); return
    fi

    local count
    count=$(python3 - "${raw}" "${csv}" "${EXTRACT_DIR}" << 'PYEOF'
import json,sys,csv as csvmod

sarif,out_csv,base=sys.argv[1],sys.argv[2],sys.argv[3]
rows=0

with open(sarif,'r',errors='replace') as fh:
    try: data=json.load(fh)
    except: print("0",end=""); sys.exit(0)

SEV={"error":"HIGH","warning":"MEDIUM","note":"LOW","none":"INFO"}

with open(out_csv,'a',newline='',encoding='utf-8') as fh:
    wr=csvmod.writer(fh,quoting=csvmod.QUOTE_ALL)
    for run in data.get("runs",[]):
        rules={r["id"]:r for r in run.get("tool",{}).get("driver",{}).get("rules",[])}
        for res in run.get("results",[]):
            rid   = res.get("ruleId","")
            rule  = rules.get(rid,{})
            sev   = SEV.get(res.get("kind","warning"),"MEDIUM")
            title = rule.get("name","") or rid
            msg   = res.get("message",{}).get("text","").replace("\n"," ")
            for loc in res.get("locations",[]):
                phys = loc.get("physicalLocation",{})
                path = phys.get("artifactLocation",{}).get("uri","").replace(base.rstrip("/")+"/","")
                line = str(phys.get("region",{}).get("startLine",""))
                cwe  = "; ".join(t.get("id","") for t in rule.get("properties",{}).get("tags",[]) if t.get("id","").startswith("CWE"))
                wr.writerow(["CodeQL",path,line,sev,rid,"codeql",title,msg,cwe,f"See CodeQL docs for {rid}"])
                rows+=1

print(rows,end="")
PYEOF
    )
    log_ok "CodeQL complete — ${count} finding(s)"
    PASSED_MODULES+=(codeql)
}

# ── MODULE: YARA ──────────────────────────────────────────────────────────────

run_yara() {
    local csv="${REPORT_DIR}/yara.csv"
    log_mod "yara" "Starting YARA pattern scan..."
    csv_header "${csv}"

    local bin; bin=$(tool_path yara)
    if [[ -z "${bin}" ]]; then
        log_skip "YARA not installed — run './install' first"
        echo "[YARA] Not installed" >> "${ERROR_LOG}"
        SKIPPED_MODULES+=(yara); return
    fi

    local rules_dir="${TOOLS_DIR}/rules/yara"
    if [[ ! -d "${rules_dir}" ]]; then
        log_skip "YARA rules not found at ${rules_dir} — run './install' first"
        SKIPPED_MODULES+=(yara); return
    fi

    log_vb "Binary: ${bin}"
    log_vb "Rules : ${rules_dir}"

    local count=0

    while IFS= read -r -d '' rule_file; do
        local rule_name; rule_name=$(basename "${rule_file}" .yar)
        local tmp_out; tmp_out=$(mktemp)

        # -s prints matched strings with byte offsets (0xOFFSET:$var: content)
        # which lets us derive exact line numbers
        "${bin}" -r -w -s "${rule_file}" "${EXTRACT_DIR}" > "${tmp_out}" 2>>"${ERROR_LOG}" || true

        count=$(python3 - "${tmp_out}" "${csv}" "${EXTRACT_DIR}" \
                         "${rule_name}" "${count}" << 'PYEOF'
import sys, re, csv as csvmod

tmp_out, csv_path, base, rule_name, count_str = \
    sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5]
count = int(count_str)
base  = base.rstrip("/")

def offset_to_line(filepath, offset):
    try:
        with open(filepath, 'rb') as f:
            return f.read(offset).count(b'\n') + 1
    except Exception:
        return ""

with open(tmp_out, 'r', errors='replace') as fh:
    lines = fh.readlines()

# YARA -s output format:
#   RuleName /absolute/path/to/file        ← header
#   0x1a:$string_var: matched content      ← one per matched string
#   RuleName /another/file
#   ...

with open(csv_path, 'a', newline='', encoding='utf-8') as fh:
    wr = csvmod.writer(fh, quoting=csvmod.QUOTE_ALL)
    i = 0
    while i < len(lines):
        hdr = re.match(r'^(\S+)\s+(/\S+)', lines[i].rstrip('\n'))
        if not hdr:
            i += 1
            continue

        match_rule = hdr.group(1)
        match_file = hdr.group(2)
        rel_file   = match_file.replace(base + "/", "", 1)

        # Collect all string-match lines that follow this header
        j = i + 1
        matches = []
        while j < len(lines):
            sm = re.match(r'^(0x[0-9a-fA-F]+):\$(\S+?):\s*(.*)', lines[j].rstrip('\n'))
            if not sm:
                break
            matches.append((int(sm.group(1), 16), sm.group(2)))
            j += 1

        # ONE row per (rule, file) — use lowest offset to get the first line number
        if matches:
            first_offset = min(m[0] for m in matches)
            lineno = offset_to_line(match_file, first_offset)
            str_names = ", ".join(f"${m[1]}" for m in matches[:5])
            extra = f" (+{len(matches)-5} more)" if len(matches) > 5 else ""
            desc = (f"File matched YARA rule '{match_rule}' — "
                    f"strings: {str_names}{extra}  [ruleset: {rule_name}]")
        else:
            lineno = ""
            desc = f"File matched YARA rule '{match_rule}'  [ruleset: {rule_name}]"

        wr.writerow([
            "YARA", rel_file, str(lineno), "HIGH",
            match_rule, "malware-pattern",
            f"YARA Rule Match: {match_rule}",
            desc, "", "Investigate file; quarantine if malicious"
        ])
        count += 1
        i = j

print(count, end="")
PYEOF
        )
        rm -f "${tmp_out}"
    done < <(find "${rules_dir}" -name "*.yar" -print0 2>/dev/null)

    log_ok "YARA scan complete — ${count} match(es)"
    PASSED_MODULES+=(yara)
}

# ── Dispatch module ───────────────────────────────────────────────────────────

run_module() {
    local mod="$1"
    case "${mod}" in
        semgrep)           run_semgrep ;;
        bandit)            run_bandit ;;
        pattern)           run_pattern ;;
        secrets)           run_secrets ;;
        gitleaks)          run_gitleaks ;;
        trivy)             run_trivy ;;
        dependency_check)  run_dependency_check ;;
        checkov)           run_checkov ;;
        codeql)            run_codeql ;;
        yara)              run_yara ;;
        *)                 log_warn "Unknown module: ${mod}" ;;
    esac
}


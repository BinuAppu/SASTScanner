show_version() {
    echo "sastscan ${VERSION}"
    echo "Open-source SAST Scanner — MIT License"
}

# ── AI Configuration ──────────────────────────────────────────────────────────

configure_ai() {
    log_sec "Configuring AI for SAST Scanning"
    log_info "Configuration will be stored (encrypted) in: ${AI_CONFIG_FILE}"
    echo ""

    local ai_url ai_model ai_api_version ai_sub_key ai_enc_key ai_enc_key2

    read -rp "  URL            : " ai_url
    read -rp "  Model Name     : " ai_model
    read -rp "  API Version    : " ai_api_version
    read -rsp "  Subscription Key (hidden) : " ai_sub_key; echo ""
    read -rsp "  Encryption Key  (hidden)  : " ai_enc_key;  echo ""
    read -rsp "  Confirm Enc Key (hidden)  : " ai_enc_key2; echo ""

    if [[ "${ai_enc_key}" != "${ai_enc_key2}" ]]; then
        log_error "Encryption keys do not match"
        exit 1
    fi

    if [[ -z "${ai_url}" || -z "${ai_model}" || -z "${ai_enc_key}" ]]; then
        log_error "URL, Model Name, and Encryption Key are required"
        exit 1
    fi

    log_info "Encrypting and saving configuration..."

    SAST_AI_URL="${ai_url}" \
    SAST_AI_MODEL="${ai_model}" \
    SAST_AI_VER="${ai_api_version}" \
    SAST_AI_SUBKEY="${ai_sub_key}" \
    SAST_ENC_KEY="${ai_enc_key}" \
    SAST_AI_CONFIG_FILE="${AI_CONFIG_FILE}" \
    python3 << 'PYEOF'
import os, sys, json, base64
try:
    from cryptography.fernet import Fernet
    from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
    from cryptography.hazmat.primitives import hashes
except ImportError:
    print("ERROR: 'cryptography' package required.  Run: pip3 install cryptography", file=sys.stderr)
    sys.exit(1)

def derive_key(password, salt):
    kdf = PBKDF2HMAC(algorithm=hashes.SHA256(), length=32, salt=salt, iterations=100_000)
    return base64.urlsafe_b64encode(kdf.derive(password.encode()))

enc_key    = os.environ["SAST_ENC_KEY"]
out_file   = os.environ["SAST_AI_CONFIG_FILE"]
config = {
    "url":             os.environ.get("SAST_AI_URL",    ""),
    "modelName":       os.environ.get("SAST_AI_MODEL",  ""),
    "apiVersion":      os.environ.get("SAST_AI_VER",    ""),
    "subscriptionKey": os.environ.get("SAST_AI_SUBKEY", ""),
}

salt    = os.urandom(16)
key     = derive_key(enc_key, salt)
token   = Fernet(key).encrypt(json.dumps(config).encode())
payload = base64.b64encode(salt).decode() + ":" + token.decode()

os.makedirs(os.path.dirname(out_file) or ".", exist_ok=True)
with open(out_file, "w") as fh:
    fh.write(payload)
print(f"[OK] AI configuration saved to {out_file}")
PYEOF

    local rc=$?
    if [[ ${rc} -eq 0 ]]; then
        log_ok "AI configuration saved to: ${AI_CONFIG_FILE}"
        log_info "Run future scans with:  sastscan --zip <file> --name <name> --useAI --encKey <key>"
    else
        log_error "Failed to save AI configuration"
        exit 1
    fi
}

# ── AI Scan ───────────────────────────────────────────────────────────────────

run_ai_scan() {
    log_sec "Running AI-Powered Analysis"

    if [[ ! -f "${AI_CONFIG_FILE}" ]]; then
        log_error "AI configuration not found.  Run: sastscan --ConfigureAI"
        return 1
    fi

    local ai_scan_script="${LIB_DIR}/ai_scan.py"
    if [[ ! -f "${ai_scan_script}" ]]; then
        log_error "AI scan script not found: ${ai_scan_script}"
        return 1
    fi

    local ai_csv="${REPORT_DIR}/ai_findings.csv"
    log_info "Decrypting AI configuration and analysing findings..."

    SAST_ENC_KEY="${ENC_KEY}" \
    SAST_AI_CONFIG="${AI_CONFIG_FILE}" \
    SAST_REPORT_DIR="${REPORT_DIR}" \
    SAST_AI_CSV="${ai_csv}" \
    SAST_EXTRACT_DIR="${EXTRACT_DIR}" \
    python3 "${ai_scan_script}" 2>>"${ERROR_LOG}"

    local rc=$?
    if [[ ${rc} -ne 0 ]]; then
        log_warn "AI analysis encountered errors — check ${ERROR_LOG}"
        return 1
    fi

    if [[ -f "${ai_csv}" ]]; then
        local cnt; cnt=$(wc -l < "${ai_csv}")
        cnt=$((cnt - 1))
        log_ok "AI analysis complete — ${cnt} suggestion(s) generated: ${ai_csv}"
    else
        log_warn "AI analysis produced no output"
    fi
}

# ── Argument Parsing ──────────────────────────────────────────────────────────

parse_args() {
    [[ $# -eq 0 ]] && { show_usage; exit 1; }
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -z|--zip)        ZIP_FILE="$2";    shift 2 ;;
            -n|--name)       SCAN_NAME="$2";   shift 2 ;;
            -m|--modules)    MODULES="$2";     shift 2 ;;
            -v|--verbose)    VERBOSE="$2";     shift 2 ;;
            --ConfigureAI)   CONFIGURE_AI=true; shift ;;
            --useAI|--useAi) USE_AI=true;      shift ;;
            --encKey)        ENC_KEY="$2";     shift 2 ;;
            --version)       show_version;     exit 0  ;;
            -h|--help)       show_usage;       exit 0  ;;
            *) log_error "Unknown option: $1"; show_usage; exit 1 ;;
        esac
    done
}

# ── Validation ────────────────────────────────────────────────────────────────

validate_inputs() {
    # --ConfigureAI is standalone — skip scan-related validation
    [[ "${CONFIGURE_AI}" == "true" ]] && return

    local errs=0
    [[ -z "${ZIP_FILE}" ]]             && { log_error "--zip is required";            ((errs++)); }
    [[ -n "${ZIP_FILE}" && ! -f "${ZIP_FILE}" ]] \
                                       && { log_error "File not found: ${ZIP_FILE}";  ((errs++)); }
    [[ -z "${SCAN_NAME}" ]]            && { log_error "--name is required";           ((errs++)); }
    [[ "${VERBOSE}" != "true" && "${VERBOSE}" != "false" ]] \
                                       && { log_warn "Invalid --verbose value; defaulting to 'true'"; VERBOSE=true; }
    if [[ "${USE_AI}" == "true" && -z "${ENC_KEY}" ]]; then
        log_error "--useAI requires --encKey <key>"
        ((errs++))
    fi
    [[ ${errs} -gt 0 ]] && exit 1
}

resolve_modules() {
    if [[ "${MODULES,,}" == "all" ]]; then
        SELECTED_MODULES=("${ALL_MODULES[@]}")
        return
    fi
    IFS=',' read -ra _req <<< "${MODULES,,}"
    for m in "${_req[@]}"; do
        m="${m//[[:space:]]/}"
        local ok=false
        for v in "${ALL_MODULES[@]}"; do [[ "$m" == "$v" ]] && ok=true && break; done
        if $ok; then SELECTED_MODULES+=("$m")
        else         log_warn "Unknown module '${m}' — skipping"; fi
    done
    [[ ${#SELECTED_MODULES[@]} -eq 0 ]] && { log_error "No valid modules selected"; exit 1; }
}

# ── Directory + Zip Setup ─────────────────────────────────────────────────────

setup_dirs() {
    local dt; dt=$(date '+%Y-%m-%d_%H-%M-%S')
    SCAN_DIR="${SCAN_NAME}_${dt}"
    EXTRACT_DIR="${SCAN_DIR}/Extracted"
    REPORT_DIR="${SCAN_DIR}/Report"
    DEBUG_DIR="${SCAN_DIR}/Debug"
    ERROR_LOG="${DEBUG_DIR}/error.txt"

    log_info "Creating scan workspace: ${SCAN_DIR}"
    mkdir -p "${EXTRACT_DIR}" "${REPORT_DIR}" "${DEBUG_DIR}"

    {   echo "=== sastscan Error / Debug Log ==="
        echo "Scan   : ${SCAN_NAME}"
        echo "Zip    : ${ZIP_FILE}"
        echo "Date   : $(date '+%Y-%m-%d %H:%M:%S')"
        echo "Host   : $(hostname)"
        echo "User   : $(id -un)"
        echo "=================================="
        echo ""
    } > "${ERROR_LOG}"

    log_ok "Workspace ready"
    log_vb "  Extracted : ${EXTRACT_DIR}"
    log_vb "  Report    : ${REPORT_DIR}"
    log_vb "  Debug     : ${DEBUG_DIR}"
}

extract_zip() {
    log_info "Extracting: ${ZIP_FILE}"
    if ! command -v unzip &>/dev/null; then
        log_error "'unzip' not found. Install it: sudo apt-get install unzip"
        exit 1
    fi
    if unzip -q "${ZIP_FILE}" -d "${EXTRACT_DIR}" 2>>"${ERROR_LOG}"; then
        local cnt; cnt=$(find "${EXTRACT_DIR}" -type f | wc -l)
        log_ok "Extracted ${cnt} file(s) → ${EXTRACT_DIR}"
    else
        log_error "Failed to extract ZIP (see ${ERROR_LOG})"
        exit 1
    fi
}

# ── CSV Helpers ───────────────────────────────────────────────────────────────

csv_header() {
    echo "Module,File,Line,Severity,RuleID,Category,Title,Description,CWE,Recommendation" > "$1"
}

# Escape a value for a CSV cell (wrap in quotes, escape inner quotes)
_esc() { local v="${*//\"/\"\"}"; printf '"%s"' "${v}"; }

# Append one row: module file line severity ruleid category title desc cwe rec
csv_row() {
    local f="$1"; shift
    printf '%s,%s,%s,%s,%s,%s,%s,%s,%s,%s\n' \
        "$(_esc "$1")" "$(_esc "$2")" "$(_esc "$3")" "$(_esc "$4")" \
        "$(_esc "$5")" "$(_esc "$6")" "$(_esc "$7")" "$(_esc "$8")" \
        "$(_esc "$9")" "$(_esc "${10:-}")" >> "${f}"
}

# ── Tool Path Helper ──────────────────────────────────────────────────────────
tool_path() {
    local name="$1"
    local cand="${TOOLS_DIR}/bin/${name}"
    command -v "${name}" 2>/dev/null || { [[ -x "${cand}" ]] && echo "${cand}"; }
}

# ── MODULE: Semgrep ───────────────────────────────────────────────────────────

run_semgrep() {
    local csv="${REPORT_DIR}/semgrep.csv"
    local raw="${DEBUG_DIR}/semgrep_raw.json"
    log_mod "semgrep" "Starting semantic analysis scan..."
    csv_header "${csv}"

    local bin; bin=$(tool_path semgrep)
    if [[ -z "${bin}" ]]; then
        log_skip "Semgrep not installed — run './install' first"
        echo "[SEMGREP] Not installed" >> "${ERROR_LOG}"
        SKIPPED_MODULES+=(semgrep); return
    fi

    local rules_dir="${TOOLS_DIR}/rules/semgrep"

    # Directories that require Semgrep Pro (paid) and break the OSS scanner.
    local _pro_only=(apex elixir)

    # Build --config args from valid OSS rule directories only:
    #   • skip hidden dirs (.github, .git, etc.)
    #   • skip Semgrep Pro-only language dirs
    #   • skip dirs that contain no YAML file with a 'rules:' key
    local cfg_args=()
    if [[ -d "${rules_dir}" ]]; then
        while IFS= read -r -d '' d; do
            local _name; _name=$(basename "${d}")
            local _skip=false
            for _p in "${_pro_only[@]}"; do
                [[ "${_name}" == "${_p}" ]] && _skip=true && break
            done
            ${_skip} && continue
            grep -rlq "^rules:" "${d}" \
                --include="*.yaml" --include="*.yml" 2>/dev/null \
                && cfg_args+=(--config "${d}")
        done < <(find "${rules_dir}" -mindepth 1 -maxdepth 1 \
                     -type d -not -name '.*' -print0 2>/dev/null)
    fi
    # Fall back to auto (requires internet) if no valid local dirs found
    [[ ${#cfg_args[@]} -eq 0 ]] && cfg_args=(--config auto)

    log_vb "Binary : ${bin}"
    log_vb "Config : ${#cfg_args[@]} rule directories"
    log_vb "Target : ${EXTRACT_DIR}"

    "${bin}" --json --quiet "${cfg_args[@]}" "${EXTRACT_DIR}" > "${raw}" 2>>"${ERROR_LOG}" || true

    if [[ ! -s "${raw}" ]]; then
        log_warn "Semgrep produced no output"
        FAILED_MODULES+=(semgrep); return
    fi

    local count
    count=$(python3 - "${raw}" "${csv}" "${EXTRACT_DIR}" << 'PYEOF'
import json, sys, csv as csvmod

raw, out_csv, base = sys.argv[1], sys.argv[2], sys.argv[3]
rows = 0

with open(raw, 'r', errors='replace') as fh:
    try:
        data = json.load(fh)
    except Exception as e:
        print(f"0", end="")
        sys.exit(0)

results = data.get("results", [])

with open(out_csv, 'a', newline='', encoding='utf-8') as fh:
    wr = csvmod.writer(fh, quoting=csvmod.QUOTE_ALL)
    for r in results:
        path  = r.get("path", "").replace(base.rstrip("/") + "/", "")
        line  = str(r.get("start", {}).get("line", ""))
        extra = r.get("extra", {})
        sev   = (extra.get("severity") or r.get("severity") or "MEDIUM").upper()
        rid   = r.get("check_id", "")
        msg   = (extra.get("message") or "").replace("\n", " ")
        meta  = extra.get("metadata", {})
        cwe   = ", ".join(meta.get("cwe", [])) if isinstance(meta.get("cwe"), list) else str(meta.get("cwe", ""))
        cat   = meta.get("category", "security")
        fix   = meta.get("fix", "") or "Review and remediate finding"
        wr.writerow(["Semgrep", path, line, sev, rid, cat, "Semgrep Finding", msg, cwe, fix])
        rows += 1

print(rows, end="")
PYEOF
    )
    log_ok "Semgrep complete — ${count} finding(s)"
    PASSED_MODULES+=(semgrep)
}

# ── MODULE: Bandit ────────────────────────────────────────────────────────────

run_bandit() {
    local csv="${REPORT_DIR}/bandit.csv"
    local raw="${DEBUG_DIR}/bandit_raw.json"
    log_mod "bandit" "Starting Python security analysis..."
    csv_header "${csv}"

    local bin; bin=$(tool_path bandit)
    if [[ -z "${bin}" ]]; then
        log_skip "Bandit not installed — run './install' first"
        echo "[BANDIT] Not installed" >> "${ERROR_LOG}"
        SKIPPED_MODULES+=(bandit); return
    fi

    # Check if there are Python files to scan
    local py_count; py_count=$(find "${EXTRACT_DIR}" -name "*.py" 2>/dev/null | wc -l)
    if [[ "${py_count}" -eq 0 ]]; then
        log_skip "No Python files found — skipping Bandit"
        SKIPPED_MODULES+=(bandit); return
    fi

    log_vb "Python files found: ${py_count}"

    "${bin}" -r "${EXTRACT_DIR}" -f json -o "${raw}" -q 2>>"${ERROR_LOG}" || true

    if [[ ! -s "${raw}" ]]; then
        log_warn "Bandit produced no output"
        FAILED_MODULES+=(bandit); return
    fi

    local count
    count=$(python3 - "${raw}" "${csv}" "${EXTRACT_DIR}" << 'PYEOF'
import json, sys, csv as csvmod

raw, out_csv, base = sys.argv[1], sys.argv[2], sys.argv[3]
rows = 0

with open(raw, 'r', errors='replace') as fh:
    try:
        data = json.load(fh)
    except Exception:
        print("0", end=""); sys.exit(0)

results = data.get("results", [])
sev_map = {"HIGH": "HIGH", "MEDIUM": "MEDIUM", "LOW": "LOW"}

with open(out_csv, 'a', newline='', encoding='utf-8') as fh:
    wr = csvmod.writer(fh, quoting=csvmod.QUOTE_ALL)
    for r in results:
        path   = r.get("filename", "").replace(base.rstrip("/") + "/", "")
        line   = str(r.get("line_number", ""))
        sev    = sev_map.get(r.get("issue_severity", "").upper(), "MEDIUM")
        rid    = r.get("test_id", "")
        title  = r.get("test_name", "")
        msg    = r.get("issue_text", "").replace("\n", " ")
        cwe    = r.get("issue_cwe", {}).get("id", "") if isinstance(r.get("issue_cwe"), dict) else ""
        cwe    = f"CWE-{cwe}" if cwe else ""
        fix    = "Review Bandit documentation for " + rid
        conf   = r.get("issue_confidence", "")
        cat    = "security"
        wr.writerow(["Bandit", path, line, sev, rid, cat, title, f"{msg} [Confidence: {conf}]", cwe, fix])
        rows += 1

print(rows, end="")
PYEOF
    )
    log_ok "Bandit complete — ${count} finding(s)"
    PASSED_MODULES+=(bandit)
}

# ── MODULE: Pattern ───────────────────────────────────────────────────────────

run_pattern() {
    local csv="${REPORT_DIR}/pattern.csv"
    log_mod "pattern" "Starting custom pattern matching scan..."
    csv_header "${csv}"

    python3 - "${EXTRACT_DIR}" "${csv}" << 'PYEOF'
import os, re, sys, csv as csvmod

base_dir = sys.argv[1]
out_csv  = sys.argv[2]

PATTERNS = [
    # Credentials & Secrets
    ("CRED-001", "HIGH",   "Hardcoded Password",     r'(?i)(password|passwd|pwd)\s*[=:]\s*["\'][^"\']{4,}["\']',             "CWE-259", "Use environment variables or secret managers"),
    ("CRED-002", "HIGH",   "Hardcoded Secret/Token",  r'(?i)(secret|token|api_key|apikey|auth_token)\s*[=:]\s*["\'][^"\']{8,}["\']', "CWE-798", "Store secrets in a vault or env vars"),
    ("CRED-003", "MEDIUM", "Hardcoded Username",      r'(?i)(username|user_name|uname)\s*[=:]\s*["\'][^"\']{3,}["\']',       "CWE-798", "Avoid hardcoding usernames"),
    ("CRED-004", "HIGH",   "Base64 Encoded Secret",   r'(?i)(password|secret|key)\s*[=:]\s*["\'][A-Za-z0-9+/]{20,}={0,2}["\']', "CWE-259", "Do not store encoded credentials in source"),

    # Injection
    ("INJ-001",  "HIGH",   "SQL Injection Risk",      r'(?i)(execute|exec|query|raw)\s*\(\s*["\'].*(%s|%d|\+|format|concat)', "CWE-89",  "Use parameterized queries / ORM"),
